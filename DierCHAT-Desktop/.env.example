# База API для Electron / Vite dev (см. docs/LOCAL-SETUP.md).
# По умолчанию в коде — http://localhost:9000 (локальный server.exe).
# VITE_API_BASE_URL=http://31.148.99.40:9000
#
# WebSocket (если не совпадает с API — отдельный порт nginx):
# VITE_WS_PORT=8081
# или полный URL: VITE_WS_URL=ws://31.148.99.40:8081
#
# Для продакшен-сборки на домене обычно не нужно — используется window.location.origin.

# Скопируйте в .env.production (или правьте существующий).
# Сборка под удалённый хост (проверка + exe): npm run package:host
# Только билд: npm run build:host
# PowerShell: .\scripts\build-host.ps1
#
# Рабочий прод (пример из проекта):
# VITE_API_BASE_URL=http://31.148.99.40:9000
# Или один домен с сайтом (HTTPS):
# VITE_API_BASE_URL=https://dier-chat.ru
# VITE_WS_URL=wss://dier-chat.ru
#
# Другой хост / порт WS:
# VITE_WS_PORT=8081
#
# Полный пример под HTTPS: см. .env.production.https.example
# Документация по выкладке: ../../HOSTING.md
#
# WebRTC TURN (звонки между разными сетями) — свой Coturn на VPS:
# VITE_WEBRTC_USE_TURN=1
# VITE_TURN_URLS=turn:turn.example.ru:3478
# VITE_TURN_USERNAME=user
# VITE_TURN_CREDENTIAL=secret
# VITE_STUN_URLS=stun:stun.l.google.com:19302
#
# GitHub Pages (подкаталог репозитория): VITE_BASE_PATH=/dier-chat/

# HTTPS + WSS на одном домене (сайт и API за nginx на 443)
# Скопируйте строки в .env.production перед: npm run build:host | package:host | build:web:host | android:build:release:host

VITE_API_BASE_URL=https://dier-chat.ru
# Обычно WS на том же хосте — можно не задавать (клиент соберёт wss от базы API).
# Явно, если прокси вынесли WS отдельно:
# VITE_WS_URL=wss://dier-chat.ru

# Опционально: подробные логи чата в консоли (только отладка)
# VITE_DEBUG_MESSAGES=1

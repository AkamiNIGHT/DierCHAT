# Скопируйте в keystore.properties (рядом с этим файлом, каталог android/)
# и заполните. Файл keystore.properties не коммитьте.
#
# Если keystore.properties НЕТ — release APK подписывается debug-ключом (удобно для установки с телефона).
# Для Google Play и постоянной подписи — создайте keystore и этот файл (см. APK-BUILD.md).
#
# Создание хранилища (один раз), из каталога android/:
#   keytool -genkeypair -v -storetype PKCS12 -keystore release.keystore -alias dierchat -keyalg RSA -keysize 2048 -validity 10000
#
storePassword=ВАШ_ПАРОЛЬ_ХРАНИЛИЩА
keyPassword=ВАШ_ПАРОЛЬ_КЛЮЧА
keyAlias=dierchat
# Путь относительно каталога android/
storeFile=release.keystore

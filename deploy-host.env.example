# Скопируйте в deploy-host.env (рядом с deploy-auto.bat) и подставьте свои значения.
# deploy-host.env в .gitignore — не коммитьте пароли и ключи.
# Сохраняйте как UTF-8 без BOM (в Notepad++: Кодировка — UTF-8), иначе cmd может ломать строки.

DEPLOY_HOST=31.148.99.40
DEPLOY_USER=root

# 1 — только ключ (пароль в консоли не спрашивается)
# Удалите строку или оставьте 0 — при scp и ssh OpenSSH запросит пароль root в окне консоли
USE_SSH_KEY=0
